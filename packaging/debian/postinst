#!/bin/bash

# Create hiveden user if not exists
if ! id -u hiveden >/dev/null 2>&1; then
    useradd -r -s /usr/sbin/nologin -d /opt/hiveden -c "Hiveden Service User" hiveden
fi

# Ensure application directory exists
mkdir -p /opt/hiveden

# Set ownership of application directory
chown -R hiveden:hiveden /opt/hiveden
chmod 750 /opt/hiveden

# Python dependencies are provided through Debian package dependencies,
# except for PyPI-only integrations.
if command -v pip3 >/dev/null 2>&1; then
    pip3 install --break-system-packages --no-warn-script-location pihole6api >/dev/null 2>&1 || \
    pip3 install --no-warn-script-location pihole6api >/dev/null 2>&1 || true
fi
